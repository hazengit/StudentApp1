<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Student App</title>
</head>
<body>
    <%- include ('partials/navbar.ejs') %>
    <div class="container mt-3">
        <h2>Update Student</h2>

        <!-- form to update student info -->
        <form action="/students/<%= updateStudent.id %>/update" method="POST">
            <div class="mb-3 mt-3">
                <label for="productName">Student Name:</label>
                <!-- display original name of student in the value property -->
                <input type="text" class="form-control" id=studentName" value = "<%= updateStudent.name %>" placeholder="Enter student name" name="studentName">
            </div>
            <div class="mb-3 mt-3">
                <label for="quantity">Age:</label>
                <!-- TODO: display original name of student in the value property -->
                <input type="text" class="form-control" id="age" value = "<%= updateStudent.age %>" placeholder="Enter age" name="age">
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>
</body>
</html>